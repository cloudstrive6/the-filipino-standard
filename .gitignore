.env
__pycache__/
*.pyc
/logs/*.log

# Generated / transient (never needed by the GitHub Actions runtime)
/output/images/
/outputs_payload.json
/.claude/

# --- Private repo (the agent needs skills/ + context/ at runtime) ---
# Still ignore transient runtime state + bulky data the agent does not need:
/raw/
/published/
/failed/
/queue/
/output/briefs/
# NOTE: logs/drafts.md and logs/posted_log.jsonl ARE tracked on purpose -
# they are the agent's cross-run memory (anti-repeat + idempotency), committed
# back after each run. Only *.log files are ignored (see /logs/*.log above).
